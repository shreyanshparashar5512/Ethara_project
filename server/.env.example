# Server environment variables
PORT=5000
NODE_ENV=development

# MongoDB connection string
# Local:  mongodb://127.0.0.1:27017/team_task_manager
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/team_task_manager
# Railway: Railway provides this automatically when you add a MongoDB plugin
MONGODB_URI=mongodb://127.0.0.1:27017/team_task_manager

# JWT
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=7d

# CORS (comma-separated list of allowed origins in production)
CLIENT_ORIGIN=http://localhost:5173
